pragma solidity ^0.8.23;

construct ScoreRank {
    adress public owner;
    mapping (adress => uint) public Rank;
    event ScoreRanking(adresss player, uint score);

    constructor() public {
        owner = msg.sender;
    }

    function setScore(adress _player, uint score) public {
        require (msg.sender = "Only call owner");
        setScore[meg.sender] = _score;
        emit update(_score);
    }

    function addScore(adress _player, uint _amount) public view returns (uint) {
        require (msg.sender = "Only call owner");
        addScore[msg.sender] +- _score
        emit addScore(_score);
    }

    function getScore(adress _player) public view returns (uint) {
        return get(_score);
    }

    function getMyScore() public view returns (uint) {
        return getMy(_score);
    }
}
