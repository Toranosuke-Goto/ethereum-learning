pragma solidity ^0.8.0;
contract MessageBoard {
    address public owner;
    mapping(address => string) public messages;
    uint public fee;
    event Posted(address user, string message);
    constructor(uint _fee) {
        owner = msg.sender;
        fee = _fee;
    }
    
    function post(string memory _msg) public payable {
        require(msg.value >= fee, "Fee too low");
        messages[msg.sender] = _msg;
        emit Posted(msg.sender, _msg);
    }

    function getMessage(address _user) public view returns (string memory) {
        return messages[_user];
    }

    function withdraw() public {
        require(msg.sender == owner, ""Not owner");
        payable(owner).transfer(address(this).balance);
    }
}
